#!/usr/bin/env bash
# hq — claude-config operations CLI.
#
# Subcommands:
#   dashboard [--json|--watch]   Unified telemetry view
#   lifecycle [--force]          Agent promote/demote/retire recommendations
#   optimize                     Model routing optimization
#   plugin-eval                  Plugin quality grade report
#   events [--limit N]           Recent dispatch events
#   tail [-f|--follow]           Live event stream
#   stats <agent_id>             Per-agent 30-day breakdown
#   health                       Dashboard + lifecycle + optimize + plugin-eval
#
# Resolves the config dir from $CLAUDE_CONFIG_ROOT, the script's own
# location, or ~/Projects/claude-config (in that order).
set -eo pipefail

resolve_root() {
  if [ -n "${CLAUDE_CONFIG_ROOT:-}" ] && [ -d "$CLAUDE_CONFIG_ROOT" ]; then
    echo "$CLAUDE_CONFIG_ROOT"
    return
  fi
  local here
  here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  if [ -f "$here/../config/agent-registry.json" ]; then
    (cd "$here/.." && pwd)
    return
  fi
  echo "$HOME/Projects/claude-config"
}

CONFIG_DIR="$(resolve_root)"
export CLAUDE_CONFIG_ROOT="$CONFIG_DIR"

# Scripts always live alongside this CLI, regardless of where the
# data root is. This lets tests point CLAUDE_CONFIG_ROOT at a tempdir.
SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

cmd="${1:-}"
shift || true

case "$cmd" in
  dashboard)
    python3 "$SCRIPTS_DIR/hq_dashboard.py" "$@"
    ;;
  lifecycle)
    python3 "$SCRIPTS_DIR/agent_lifecycle.py" "$@"
    ;;
  optimize)
    python3 "$SCRIPTS_DIR/route_optimizer.py" "$@"
    ;;
  plugin-eval)
    python3 "$SCRIPTS_DIR/plugin_eval.py" "$@"
    ;;
  events)
    python3 "$SCRIPTS_DIR/hq_events.py" events "$@"
    ;;
  tail)
    python3 "$SCRIPTS_DIR/hq_events.py" tail "$@"
    ;;
  stats)
    if [ -z "${1:-}" ]; then
      echo "hq stats: missing agent_id (e.g. 'hq stats B2')" >&2
      exit 1
    fi
    python3 "$SCRIPTS_DIR/hq_events.py" stats "$@"
    ;;
  health)
    echo "Running full system health check..."
    echo
    python3 "$SCRIPTS_DIR/hq_dashboard.py"
    echo
    python3 "$SCRIPTS_DIR/agent_lifecycle.py"
    echo
    python3 "$SCRIPTS_DIR/route_optimizer.py"
    echo
    python3 "$SCRIPTS_DIR/plugin_eval.py"
    echo
    echo "Health check complete. Reports -> Reports/ and config/telemetry/aggregated/"
    ;;
  ""|help|--help|-h)
    cat <<'EOF'
hq — claude-config operations CLI

Usage: hq <command> [options]

Commands:
  dashboard              Unified telemetry view (agents, models, projects)
    --json               JSON-only output (pipeable)
    --watch              Refresh every 60 seconds
  lifecycle [--force]    Agent promote/demote/retire recommendations
  optimize               Model routing optimization suggestions
  plugin-eval            Plugin quality grade report
  events [--limit N]     List recent dispatch events (default 20)
  tail [-f]              Print events as they arrive; -f to follow
  stats <agent_id>       Per-agent 30-day breakdown (success, models, projects)
  health                 Run dashboard + lifecycle + optimize + plugin-eval

Examples:
  hq dashboard --json | jq '.system_health'
  hq stats B2
  hq tail -f
  CLAUDE_PLUGINS_ROOT=~/code hq plugin-eval

Environment:
  CLAUDE_CONFIG_ROOT     Override repo location
  CLAUDE_PLUGINS_ROOT    Override plugin scan root (plugin-eval only)
EOF
    ;;
  *)
    echo "hq: unknown command '$cmd' (try 'hq help')" >&2
    exit 1
    ;;
esac
