{
  "includeGitInstructions": true,
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(flutter *)",
      "Bash(dart *)",
      "Bash(gh *)",
      "Bash(brew *)",
      "Bash(mkdir *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(tsx *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(curl *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(env *)",
      "Bash(open *)",
      "Read(~/.zshrc)"
    ],
    "deny": [],
    "ask": [
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(gh repo delete*)",
      "Bash(shred *)"
    ]
  },
  "defaultMode": "bypassPermissions",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "description": "Print active Jarvis model label + emoji",
            "command": "MODEL=$(jq -r '.model // \"sonnet\"' ~/.claude/settings.json 2>/dev/null); if echo \"$MODEL\" | grep -qE 'openrouter|groq/|hf/|cerebras|local/|google/'; then EMOJI='🆓'; elif echo \"$MODEL\" | grep -q 'haiku'; then EMOJI='💛'; elif echo \"$MODEL\" | grep -q 'opus'; then EMOJI='🔴'; else EMOJI='🔶'; fi; echo \"JARVIS_MODEL: $MODEL $EMOJI\""
          },
          {
            "type": "command",
            "description": "List available secret keys (names only)",
            "command": "SFILE=\"$HOME/.claude/secrets/secrets.env\"; if [ -f \"$SFILE\" ]; then KEYS=$(grep -v '^#' \"$SFILE\" | grep '=' | cut -d= -f1 | paste -sd ',' -); echo \"AVAILABLE_SECRETS: $KEYS\"; else echo 'AVAILABLE_SECRETS: none — secrets.env bulunamadi'; fi"
          },
          {
            "type": "command",
            "description": "Show currently enabled MCP servers",
            "command": "MCPS=$(jq -r '.mcpServers | keys | join(\", \")' ~/.claude/settings.json 2>/dev/null); echo \"🔌 MCP_ACTIVE: $MCPS — Kullanmayacaklarini /mcp ile kapat\""
          },
          {
            "type": "command",
            "description": "Update projects index cache (best-effort)",
            "command": "bash ~/Projects/claude-config/projects/scripts/project_index.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "description": "Check pending Reports (best-effort)",
            "command": "bash ~/Projects/claude-config/config/reports_check.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "description": "Sync core CLAUDE + skills + agents + agent-registry from claude-config clone to ~/.claude (every session)",
            "command": "bash \"__CLAUDE_CONFIG_ROOT__/config/session_sync_claude_config.sh\" \"__CLAUDE_CONFIG_ROOT__\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "description": "Print Jarvis routing and agent truth policy",
            "command": "echo \"JARVIS_POLICY: Sen implementer degilsin; isi agent'lar yapar. Truth source = __CLAUDE_CONFIG_ROOT__/agents/**/AGENT.md + __CLAUDE_CONFIG_ROOT__/config/agent-registry.json. ~/.claude/agents/*.md generated mirror.\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "description": "Auto migration check on prompt submit",
            "command": "bash __CLAUDE_CONFIG_ROOT__/projects/scripts/migration_check.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "description": "Block editing secrets files via tool input",
            "command": "f=$(echo \"$CLAUDE_TOOL_INPUT\" | python3 -c \"import sys,json;print(json.load(sys.stdin).get('file_path',''))\" 2>/dev/null); case \"$f\" in *.env*|*/secrets/*) echo \"BLOCKED: $f is a secrets file — edit ~/.claude/secrets/ directly\"; exit 2;; esac"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "description": "Verification gates for git commit/push (warn-only by default)",
            "command": "python3 __CLAUDE_CONFIG_ROOT__/scripts/gate_check.py 2>&1 || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task|Bash",
        "hooks": [
          {
            "type": "command",
            "description": "Append dispatch event to telemetry log (best-effort)",
            "command": "python3 __CLAUDE_CONFIG_ROOT__/scripts/log_dispatch.py 2>/dev/null || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "description": "Fire notification script (best-effort)",
            "command": "bash ~/Projects/claude-config/config/notify.sh \"\" \"🔔\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "description": "Notify task completion (best-effort)",
            "command": "bash ~/Projects/claude-config/config/notify.sh \"Görev tamamlandı ✅\" \"✅\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "description": "Post-run reflection + apply (background)",
            "command": "bash ~/Projects/claude-config/config/dispatch-reflect.sh --last 20 --apply >> ~/Projects/.watchdog/reflect-output.log 2>&1 &"
          }
        ]
      }
    ]
  },
  "effortLevel": "low",
  "disablePromptCaching": false,
  "maxOutputTokens": 8192,
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git"
      ]
    },
    "atlassian": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote@latest",
        "https://mcp.atlassian.com/v1/mcp"
      ]
    },
    "flutter-dev": {
      "command": "npx",
      "args": [
        "-y",
        "flutter-dev-mcp"
      ]
    },
    "firebase": {
      "command": "npx",
      "args": [
        "-y",
        "@gannonh/firebase-mcp"
      ],
      "env": {
        "SERVICE_ACCOUNT_KEY_PATH": "${FIREBASE_SERVICE_ACCOUNT_PATH}"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "jcodemunch": {
      "command": "uvx",
      "args": [
        "jcodemunch-mcp"
      ]
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-fetch-server"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "codex": {
      "command": "codex",
      "args": ["mcp-server"],
      "env": {}
    }
  },
  "model": "claude-sonnet-4-6"
}
