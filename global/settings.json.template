{
  "includeGitInstructions": true,
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(flutter *)",
      "Bash(dart *)",
      "Bash(gh *)",
      "Bash(brew *)",
      "Bash(mkdir *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(tsx *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(curl *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(env *)",
      "Bash(open *)",
      "Read(~/.zshrc)"
    ],
    "deny": [],
    "ask": [
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(gh repo delete*)",
      "Bash(shred *)"
    ]
  },
  "defaultMode": "bypassPermissions",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "MODEL=$(jq -r '.model // \"sonnet\"' ~/.claude/settings.json 2>/dev/null); if echo \"$MODEL\" | grep -qE 'openrouter|groq/|hf/|cerebras|local/|google/'; then EMOJI='🆓'; elif echo \"$MODEL\" | grep -q 'haiku'; then EMOJI='💛'; elif echo \"$MODEL\" | grep -q 'opus'; then EMOJI='🔴'; else EMOJI='🔶'; fi; echo \"JARVIS_MODEL: $MODEL $EMOJI\""
          },
          {
            "type": "command",
            "command": "SFILE=\"$HOME/.claude/secrets/secrets.env\"; if [ -f \"$SFILE\" ]; then KEYS=$(grep -v '^#' \"$SFILE\" | grep '=' | cut -d= -f1 | paste -sd ',' -); echo \"AVAILABLE_SECRETS: $KEYS\"; else echo 'AVAILABLE_SECRETS: none — secrets.env bulunamadi'; fi"
          },
          {
            "type": "command",
            "command": "MCPS=$(jq -r '.mcpServers | keys | join(\", \")' ~/.claude/settings.json 2>/dev/null); echo \"🔌 MCP_ACTIVE: $MCPS — Kullanmayacaklarini /mcp ile kapat\""
          },
          {
            "type": "command",
            "command": "bash ~/Projects/claude-config/projects/scripts/project_index.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash ~/Projects/claude-config/config/reports_check.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs && $HOME/.mempalace-venv/bin/python3 -m mempalace mine ~/Projects >> ~/.claude/logs/mempalace-mine.log 2>&1 &"
          },
          {
            "type": "command",
            "command": "$HOME/.mempalace-venv/bin/python3 -m mempalace wake-up 2>/dev/null || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/musabkara/Projects/claude-config/projects/scripts/migration_check.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(echo \"$CLAUDE_TOOL_INPUT\" | python3 -c \"import sys,json;print(json.load(sys.stdin).get('file_path',''))\" 2>/dev/null); case \"$f\" in *.env*|*/secrets/*) echo \"BLOCKED: $f is a secrets file — edit ~/.claude/secrets/ directly\"; exit 2;; esac"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Projects/claude-config/config/notify.sh \"\" \"🔔\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Projects/claude-config/config/notify.sh \"Görev tamamlandı ✅\" \"✅\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash ~/Projects/claude-config/config/dispatch-reflect.sh --last 20 --apply >> ~/Projects/.watchdog/reflect-output.log 2>&1 &"
          }
        ]
      }
    ]
  },
  "effortLevel": "low",
  "disablePromptCaching": false,
  "maxOutputTokens": 8192,
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "git": {
      "command": "/Users/musabkara/.local/bin/uvx",
      "args": [
        "mcp-server-git"
      ]
    },
    "atlassian": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote@latest",
        "https://mcp.atlassian.com/v1/mcp"
      ]
    },
    "flutter-dev": {
      "command": "npx",
      "args": [
        "-y",
        "flutter-dev-mcp"
      ]
    },
    "firebase": {
      "command": "npx",
      "args": [
        "-y",
        "@gannonh/firebase-mcp"
      ],
      "env": {
        "SERVICE_ACCOUNT_KEY_PATH": "${FIREBASE_SERVICE_ACCOUNT_PATH}"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "jcodemunch": {
      "command": "/Users/musabkara/.local/bin/uvx",
      "args": [
        "jcodemunch-mcp"
      ]
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-fetch-server"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "dbhub": {
      "command": "npx",
      "args": [
        "-y",
        "dbhub@latest"
      ]
    },
    "magic-ui": {
      "command": "npx",
      "args": [
        "-y",
        "@21st-dev/magic-mcp"
      ]
    },
    "mermaid": {
      "command": "npx",
      "args": [
        "-y",
        "@narasimhaponnada/mermaid-mcp-server"
      ]
    },
    "meshy": {
      "command": "npx",
      "args": [
        "-y",
        "meshy-ai-mcp-server"
      ],
      "env": {
        "MESHY_API_KEY": "${MESHY_API_KEY}"
      }
    }
  },
  "model": "claude-sonnet-4-6"
}
