<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.jarvis.auto-dream</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__CLAUDE_CONFIG_ROOT__/global/scripts/auto-dream.sh</string>
  </array>

  <!-- Run weekly: every Sunday at 03:00 local -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key>
    <integer>0</integer>
    <key>Hour</key>
    <integer>3</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>__HOME__/.claude/logs/auto-dream.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/.claude/logs/auto-dream.log</string>

  <key>RunAtLoad</key>
  <false/>
  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
